-- Anti-Aim Toggle Function
antiAimToggle.MouseButton1Click:Connect(function()
    antiAimActive = not antiAimActive
    antiAimToggle.Text = antiAimActive and 'ON' or 'OFF'
    antiAimToggle.BackgroundColor3 = antiAimActive and Color3.fromRGB(80, 60, 200) or Color3.fromRGB(40, 40, 60)
    
    if antiAimActive then
        antiAimConnection = RunService.Heartbeat:Connect(function()
            if not antiAimActive or not humanoidRootPart then return end
            
            local target = getClosestEnemy()
            if not target or not target.Character then return end
            
            local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
            if not targetHRP then return end
            
            local lookVector = (targetHRP.Position - humanoidRootPart.Position).Unit
            
            if antiAimType == "Jitter" then
                antiAimAngle = antiAimAngle + 0.1
                local jitterAngle = math.sin(antiAimAngle) * 0.3
                humanoidRootPart.CFrame = CFrame.lookAt(
                    humanoidRootPart.Position,
                    targetHRP.Position + Vector3.new(jitterAngle, 0, jitterAngle)
                )
            elseif antiAimType == "Spin" then
                antiAimYaw = antiAimYaw + 0.15
                local spinOffset = Vector3.new(math.cos(antiAimYaw) * 2, 0, math.sin(antiAimYaw) * 2)
                humanoidRootPart.CFrame = CFrame.lookAt(
                    humanoidRootPart.Position,
                    targetHRP.Position + spinOffset
                )
            elseif antiAimType == "Fake" then
                humanoidRootPart.CFrame = CFrame.lookAt(
                    humanoidRootPart.Position,
                    targetHRP.Position + Vector3.new(0, 0, 0)
                )
                -- Fake desync
                if humanoid then
                    humanoid.AutoRotate = false
                end
            elseif antiAimType == "Jitter+Spin" then
                antiAimAngle = antiAimAngle + 0.1
                antiAimYaw = antiAimYaw + 0.1
                local jitterAngle = math.sin(antiAimAngle) * 0.3
                local spinOffset = Vector3.new(math.cos(antiAimYaw) * 1.5, 0, math.sin(antiAimYaw) * 1.5)
                humanoidRootPart.CFrame = CFrame.lookAt(
                    humanoidRootPart.Position,
                    targetHRP.Position + spinOffset + Vector3.new(jitterAngle, 0, jitterAngle)
                )
            end
        end)
    else
        if antiAimConnection then
            antiAimConnection:Disconnect()
            antiAimConnection = nil
        end
        if humanoid then
            humanoid.AutoRotate = true
        end
    end
end)

-- Orbit Toggle Function
orbitToggle.MouseButton1Click:Connect(function()
    orbitActive = not orbitActive
    orbitToggle.Text = orbitActive and 'ON' or 'OFF'
    orbitToggle.BackgroundColor3 = orbitActive and Color3.fromRGB(80, 60, 200) or Color3.fromRGB(40, 40, 60)
    
    if orbitActive then
        orbitConnection = RunService.Heartbeat:Connect(function()
            if not orbitActive or not humanoidRootPart then return end
            
            local target = getClosestEnemy()
            if target and target.Character then
                local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    orbitAngle = orbitAngle + orbitSpeed
                    humanoidRootPart.CFrame = CFrame.new(
                        targetHRP.Position + Vector3.new(
                            math.cos(orbitAngle) * orbitDistance,
                            orbitHeight,
                            math.sin(orbitAngle) * orbitDistance
                        ),
                        targetHRP.Position
                    )
                end
            end
        end)
    else
        if orbitConnection then
            orbitConnection:Disconnect()
            orbitConnection = nil
        end
    end
end)

-- Slider Controls (simplified - click to adjust)
local function setupSlider(sliderFill, valueLabel, minVal, maxVal, defaultValue, callback)
    local dragging = false
    
    sliderFill.Parent.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if not dragging or input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        
        local slider = sliderFill.Parent
        local mousePos = input.Position.X
        local sliderPos = slider.AbsolutePosition.X
        local sliderSize = slider.AbsoluteSize.X
        
        local percent = math.clamp((mousePos - sliderPos) / sliderSize, 0, 1)
        local value = minVal + (maxVal - minVal) * percent
        value = math.round(value * 100) / 100
        
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        valueLabel.Text = tostring(value)
        callback(value)
    end)
end

setupSlider(speedFill, speedValue, 0.01, 0.5, 0.18, function(val)
    orbitSpeed = val
end)

