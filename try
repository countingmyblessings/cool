local function resolve_player(p)
    if not p then return end
    if p.Character and p.Character.Parent then return end
    if Neuron then pcall(function() p.Character=Neuron:get_character(p) end) end
end

task.spawn(function()
    task.wait(4)
    while true do
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer and (not p.Character or not p.Character.Parent) then resolve_player(p) end
        end
        task.wait(2)
    end
end)

