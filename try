-- ============================================================
--  UI BUILDER HELPERS
-- ============================================================
local UI = {}
function UI.Frame(props)
    local f = Instance.new("Frame")
    for k,v in pairs(props) do pcall(function() f[k]=v end) end
    return f
end
function UI.Label(props)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Font       = Enum.Font.GothamBold
    l.TextSize   = 13
    l.TextColor3 = C.Text
    l.TextXAlignment = Enum.TextXAlignment.Left
    for k,v in pairs(props) do pcall(function() l[k]=v end) end
    return l
end
function UI.Corner(radius, parent)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end
function UI.Stroke(color, thick, parent)
    local s = Instance.new("UIStroke")
    s.Color = color or C.Border
    s.Thickness = thick or 1
    s.Parent = parent
    return s
end
function UI.List(padding, parent)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, padding or 4)
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end
function UI.Pad(px, py, parent)
    local p = Instance.new("UIPadding")
    p.PaddingLeft   = UDim.new(0, px or 8)
    p.PaddingRight  = UDim.new(0, px or 8)
    p.PaddingTop    = UDim.new(0, py or 6)
    p.PaddingBottom = UDim.new(0, py or 6)
    p.Parent = parent
    return p
end

-- auto-resize frame to list content
function UI.AutoSize(frame, list, extraH)
    list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        frame.Size = UDim2.new(frame.Size.X.Scale, frame.Size.X.Offset, 0, list.AbsoluteContentSize.Y + (extraH or 16))
    end)
end

