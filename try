    local open     = false

    local wrap = UI.Frame({
        BackgroundTransparency = 1,
        Size   = UDim2.new(1,0,0,32),
        Parent = parent,
    })

    local row = UI.Frame({
        BackgroundColor3 = C.Panel,
        Size             = UDim2.new(1,0,0,32),
        BorderSizePixel  = 0,
        Parent           = wrap,
    })
    UI.Corner(5, row)

    UI.Label({Size=UDim2.new(0.55,0,1,0), Position=UDim2.new(0,10,0,0), Text=label, TextSize=12, Parent=row})
    local selLbl = UI.Label({
        Size=UDim2.new(0.4,0,1,0), Position=UDim2.new(0.55,0,0,0),
        Text=selected, TextSize=12, TextColor3=C.AccentHi,
        TextXAlignment=Enum.TextXAlignment.Right,
        Parent=row,
    })
    local arrow = UI.Label({
        Size=UDim2.new(0,20,1,0), Position=UDim2.new(1,-22,0,0),
        Text="‚Ėĺ", TextSize=14, TextColor3=C.AccentHi,
        TextXAlignment=Enum.TextXAlignment.Center,
        Parent=row,
    })

    local dropdown = UI.Frame({
        BackgroundColor3 = C.Dark,
        Size             = UDim2.new(1,0,0,0),
        Position         = UDim2.new(0,0,1,2),
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        ZIndex           = 50,
        Visible          = false,
        Parent           = wrap,
    })
    UI.Corner(5, dropdown)
    UI.Stroke(C.Accent, 1, dropdown)
    local dList = UI.List(2, dropdown)
    UI.Pad(4,4,dropdown)

    local function closeDD()
        open = false
        TweenSvc:Create(dropdown, TweenInfo.new(0.12), {Size=UDim2.new(1,0,0,0)}):Play()
        task.delay(0.13, function() dropdown.Visible=false end)
        arrow.Text = "‚Ėĺ"
    end
    local function openDD()
        open = true
        dropdown.Visible = true
        local h = #values * 26 + 8
        TweenSvc:Create(dropdown, TweenInfo.new(0.12), {Size=UDim2.new(1,0,0,h)}):Play()
        arrow.Text = "‚Ėī"
    end

    local hitbox = Instance.new("TextButton")
    hitbox.Size=UDim2.new(1,0,1,0); hitbox.BackgroundTransparency=1; hitbox.Text=""; hitbox.Parent=row
    hitbox.MouseButton1Click:Connect(function() if open then closeDD() else openDD() end end)

    for _, v in ipairs(values) do
        local opt = Instance.new("TextButton")
        opt.Size             = UDim2.new(1,0,0,22)
        opt.BackgroundColor3 = Color3.fromRGB(20,14,40)
        opt.BorderSizePixel  = 0
        opt.Text             = v
        opt.TextColor3       = v==selected and C.AccentHi or C.Text
        opt.Font             = Enum.Font.Gotham
        opt.TextSize         = 12
        opt.ZIndex           = 51
        opt.Parent           = dropdown
        UI.Corner(4, opt)
        opt.MouseButton1Click:Connect(function()
            selected = v
            selLbl.Text = v
            for _, child in ipairs(dropdown:GetChildren()) do
                if child:IsA("TextButton") then child.TextColor3 = child.Text==v and C.AccentHi or C.Text end
            end
            closeDD()
            pcall(callback, v)
        end)
    end

    return {GetValue=function() return selected end, Close=closeDD}
end

