--  SLIDER WIDGET
-- ============================================================
local function MakeSlider(parent, label, min, max, default, suffix, callback)
    local val   = default or min
    local dragging = false
    suffix = suffix or ""

    local row = UI.Frame({
        BackgroundColor3 = C.Panel,
        Size             = UDim2.new(1,0,0,44),
        BorderSizePixel  = 0,
        Parent           = parent,
    })
    UI.Corner(5, row)

    local top = UI.Label({
        Size     = UDim2.new(1,-10,0,20),
        Position = UDim2.new(0,10,0,4),
        Text     = label,
        TextSize = 12,
        Parent   = row,
    })
    local valLbl = UI.Label({
        Size             = UDim2.new(0,60,0,20),
        Position         = UDim2.new(1,-68,0,4),
        Text             = tostring(val)..suffix,
        TextSize         = 12,
        TextColor3       = C.AccentHi,
        TextXAlignment   = Enum.TextXAlignment.Right,
        Parent           = row,
    })

    local track = UI.Frame({
        BackgroundColor3 = Color3.fromRGB(30,20,55),
        Size             = UDim2.new(1,-20,0,6),
        Position         = UDim2.new(0,10,0,30),
        BorderSizePixel  = 0,
        Parent           = row,
    })
    UI.Corner(3, track)

    local fill = UI.Frame({
        BackgroundColor3 = C.Accent,
        Size             = UDim2.new((val-min)/(max-min),0,1,0),
        BorderSizePixel  = 0,
        Parent           = track,
    })
    UI.Corner(3, fill)

    local function update(inputX)
        local abs = track.AbsolutePosition
        local sz  = track.AbsoluteSize
        local t   = math.clamp((inputX - abs.X)/sz.X, 0, 1)
        val = math.floor(min + t*(max-min) + 0.5)
        fill.Size = UDim2.new(t, 0, 1, 0)
        valLbl.Text = tostring(val)..suffix
        pcall(callback, val)
    end

    local hitbox = Instance.new("TextButton")
    hitbox.Size = UDim2.new(1,0,1,0)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""
    hitbox.Parent = track

    hitbox.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(i.Position.X)
        end
    end)
    UserInput.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            update(i.Position.X)
        end
    end)
    UserInput.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    return {GetValue = function() return val end}
end

