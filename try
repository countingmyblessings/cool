local function MakeToggle(parent, label, default, callback)
    local state  = default or false
    local row    = UI.Frame({
        BackgroundColor3    = C.Panel,
        Size                = UDim2.new(1,0,0,32),
        BorderSizePixel     = 0,
        Parent              = parent,
    })
    UI.Corner(5, row)

    local lbl = UI.Label({
        Size = UDim2.new(1,-50,1,0),
        Position = UDim2.new(0,10,0,0),
        Text = label,
        TextSize = 12,
        Parent = row,
    })

    local pill = UI.Frame({
        Size             = UDim2.new(0,34,0,18),
        Position         = UDim2.new(1,-44,0.5,-9),
        BackgroundColor3 = state and C.Accent or Color3.fromRGB(40,30,60),
        BorderSizePixel  = 0,
        Parent           = row,
    })
    UI.Corner(9, pill)

    local knob = UI.Frame({
        Size             = UDim2.new(0,12,0,12),
        Position         = state and UDim2.new(0,18,0.5,-6) or UDim2.new(0,4,0.5,-6),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel  = 0,
        Parent           = pill,
    })
    UI.Corner(6, knob)

    local info = Instance.new("TextButton")
    info.Size               = UDim2.new(1,0,1,0)
    info.BackgroundTransparency = 1
    info.Text               = ""
    info.Parent             = row

    local function setVal(v)
        state = v
        pill.BackgroundColor3 = v and C.Accent or Color3.fromRGB(40,30,60)
        local goal = v and UDim2.new(0,18,0.5,-6) or UDim2.new(0,4,0.5,-6)
        TweenSvc:Create(knob, TweenInfo.new(0.12), {Position=goal}):Play()
        pcall(callback, v)
    end

    info.MouseButton1Click:Connect(function() setVal(not state) end)
    return {SetValue = setVal, GetValue = function() return state end}
end

