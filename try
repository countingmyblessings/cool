local function MakeSection(parent, title)
    local wrap = UI.Frame({BackgroundTransparency=1, Size=UDim2.new(1,0,0,24), Parent=parent})

    local hdr = UI.Frame({BackgroundColor3=C.Header, Size=UDim2.new(1,0,0,24), BorderSizePixel=0, Parent=wrap})
    UI.Corner(5, hdr)
    UI.Stroke(C.Accent, 1, hdr)
    local accent = UI.Frame({BackgroundColor3=C.Accent, Size=UDim2.new(0,3,0,14), Position=UDim2.new(0,6,0.5,-7), BorderSizePixel=0, Parent=hdr})
    UI.Corner(2, accent)
    UI.Label({Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,16,0,0), Text=title, TextSize=12, TextColor3=C.AccentHi, Font=Enum.Font.GothamBold, Parent=hdr})

    local body = UI.Frame({
        BackgroundColor3 = Color3.fromRGB(12,9,26),
        Size             = UDim2.new(1,0,0,8),
        Position         = UDim2.new(0,0,0,26),
        BorderSizePixel  = 0,
        Parent           = wrap,
        ClipsDescendants = false,
    })
    UI.Corner(5, body)
    local lst = UI.List(3, body)
    UI.Pad(6,6,body)

    local function refresh()
        local h = lst.AbsoluteContentSize.Y + 12
        body.Size  = UDim2.new(1,0,0,h)
        wrap.Size  = UDim2.new(1,0,0,h+28)
    end
    lst:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refresh)

    local api = {}
    function api:Toggle(label, default, cb)    local t=MakeToggle(body,label,default,cb)   refresh() return t end
    function api:Slider(label,mn,mx,def,sfx,cb) local s=MakeSlider(body,label,mn,mx,def,sfx,cb) refresh() return s end
    function api:Dropdown(label,vals,def,cb)   local d=MakeDropdown(body,label,vals,def,cb) refresh() return d end
    function api:Color(label,def,cb)           local c=MakeColorPicker(body,label,def,cb)  refresh() return c end
    function api:Label(text)
        local l=UI.Label({Size=UDim2.new(1,0,0,18),Text=text,TextSize=11,TextColor3=C.TextDim,Parent=body})
        refresh() return l
    end
    function api:Divider()
        local d=UI.Frame({BackgroundColor3=C.Border,Size=UDim2.new(1,0,0,1),BorderSizePixel=0,Parent=body})
        refresh() return d
    end
    return api
end

