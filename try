local function MakeColorPicker(parent, label, default, callback)
    local col = default or Color3.fromRGB(255,255,255)
    local h,s,v = Color3.toHSV(col)

    local row = UI.Frame({BackgroundColor3=C.Panel, Size=UDim2.new(1,0,0,32), BorderSizePixel=0, Parent=parent})
    UI.Corner(5, row)
    UI.Label({Size=UDim2.new(0.6,0,1,0), Position=UDim2.new(0,10,0,0), Text=label, TextSize=12, Parent=row})

    local swatch = UI.Frame({
        BackgroundColor3 = col,
        Size             = UDim2.new(0,24,0,18),
        Position         = UDim2.new(1,-32,0.5,-9),
        BorderSizePixel  = 0,
        Parent           = row,
    })
    UI.Corner(4, swatch)
    UI.Stroke(C.Border, 1, swatch)

    -- Expanded picker panel
    local picker = UI.Frame({
        BackgroundColor3 = C.Dark,
        Size             = UDim2.new(1,0,0,0),
        Position         = UDim2.new(0,0,1,2),
        BorderSizePixel  = 0,
        ClipsDescendants = true,
        ZIndex           = 50,
        Visible          = false,
        Parent           = row,
    })
    UI.Corner(6, picker)
    UI.Stroke(C.Accent,1,picker)

    local open = false
    local swBtn = Instance.new("TextButton")
    swBtn.Size=UDim2.new(1,0,1,0); swBtn.BackgroundTransparency=1; swBtn.Text=""; swBtn.ZIndex=2; swBtn.Parent=swatch

    -- Hue bar
    local hueBar = UI.Frame({BackgroundColor3=Color3.fromRGB(255,255,255), Size=UDim2.new(1,-16,0,14), Position=UDim2.new(0,8,0,8), BorderSizePixel=0, ZIndex=51, Parent=picker})
    UI.Corner(4, hueBar)
    local hueGrad = Instance.new("UIGradient")
    hueGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,   Color3.fromHSV(0,1,1)),
        ColorSequenceKeypoint.new(0.17,Color3.fromHSV(0.17,1,1)),
        ColorSequenceKeypoint.new(0.33,Color3.fromHSV(0.33,1,1)),
        ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5,1,1)),
        ColorSequenceKeypoint.new(0.67,Color3.fromHSV(0.67,1,1)),
        ColorSequenceKeypoint.new(0.83,Color3.fromHSV(0.83,1,1)),
        ColorSequenceKeypoint.new(1,   Color3.fromHSV(1,1,1)),
    })
    hueGrad.Parent = hueBar

    -- SV square (simplified: brightness slider)
    local satBar = UI.Frame({BackgroundColor3=Color3.fromHSV(h,1,1), Size=UDim2.new(1,-16,0,14), Position=UDim2.new(0,8,0,28), BorderSizePixel=0, ZIndex=51, Parent=picker})
    UI.Corner(4, satBar)
    local satGrad = Instance.new("UIGradient")
    satGrad.Color = ColorSequence.new(Color3.fromRGB(255,255,255), Color3.fromHSV(h,1,1))
    satGrad.Parent = satBar

    local briBar = UI.Frame({BackgroundColor3=Color3.fromRGB(0,0,0), Size=UDim2.new(1,-16,0,14), Position=UDim2.new(0,8,0,48), BorderSizePixel=0, ZIndex=51, Parent=picker})
    UI.Corner(4, briBar)
    local briGrad = Instance.new("UIGradient")
    briGrad.Color = ColorSequence.new(Color3.fromRGB(0,0,0), Color3.fromHSV(h,s,1))
    briGrad.Parent = briBar

    local function applyColor()
        col = Color3.fromHSV(h,s,v)
        swatch.BackgroundColor3 = col
        satBar.BackgroundColor3 = Color3.fromHSV(h,1,1)
        satGrad.Color = ColorSequence.new(Color3.fromRGB(255,255,255), Color3.fromHSV(h,1,1))
        briGrad.Color = ColorSequence.new(Color3.fromRGB(0,0,0), Color3.fromHSV(h,s,1))
        pcall(callback, col)
    end

    local function barDrag(bar, inputX, onUpdate)
        local t = math.clamp((inputX - bar.AbsolutePosition.X)/bar.AbsoluteSize.X, 0, 1)
        onUpdate(t)
        applyColor()
    end

    local draggingH, draggingS, draggingB = false,false,false
    for _, pair in ipairs({
        {hueBar, function(t) h=t end, function(b) draggingH=b end, function() return draggingH end},
        {satBar, function(t) s=t end, function(b) draggingS=b end, function() return draggingS end},
        {briBar, function(t) v=t end, function(b) draggingB=b end, function() return draggingB end},
    }) do
        local bar,setter,setDrag,getDrag = pair[1],pair[2],pair[3],pair[4]
        local hb = Instance.new("TextButton"); hb.Size=UDim2.new(1,0,1,0); hb.BackgroundTransparency=1; hb.Text=""; hb.ZIndex=52; hb.Parent=bar
        hb.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                setDrag(true); barDrag(bar,i.Position.X,setter)
            end
        end)
        UserInput.InputChanged:Connect(function(i)
            if getDrag() and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                barDrag(bar,i.Position.X,setter)
            end
        end)
        UserInput.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then setDrag(false) end
        end)
    end

    swBtn.MouseButton1Click:Connect(function()
        open = not open
        picker.Visible = open
        local goal = open and UDim2.new(1,0,0,76) or UDim2.new(1,0,0,0)
        TweenSvc:Create(picker, TweenInfo.new(0.12), {Size=goal}):Play()
    end)

    return {GetValue=function() return col end}
end

