-- ============================================================
--  GAME HELPERS
-- ============================================================
local function W2S(pos)
    local p,vis=Camera:WorldToViewportPoint(pos)
    return v2(p.X,p.Y),vis,p.Z
end
local function IsAlive(p)
    resolve_player(p)
    local c=p.Character; if not c then return false end
    if HitHandler and HitHandler.isAlive then local ok,r=pcall(function() return HitHandler:isAlive(c) end) if ok then return r end end
    if States and States.GetStateValue then local ok,hp=pcall(function() return States:GetStateValue(c,"Health",150) end) if ok and hp then return hp>0 end end
    local h=c:FindFirstChildOfClass("Humanoid"); return h and h.Health>0 or false
end
local function IsSameTeam(p)
    if p==LocalPlayer then return true end
    if GameplayHandler then
        local lt,pt
        pcall(function() local _,id=GameplayHandler:GetLocalDuel() if id then lt=GameplayHandler:GetPlayerTeam(id,LocalPlayer) pt=GameplayHandler:GetPlayerTeam(id,p) end end)
        if lt and pt then return lt.id==pt.id end
    end
    if LocalPlayer.Team and p.Team then return p.Team==LocalPlayer.Team end
    return false
end
local function GetHealth(p)
    local c=p.Character; if not c then return 0 end
    if States and States.GetStateValue then
        local ok,hp=pcall(function() return States:GetStateValue(c,"Health",150) end)
        if ok and hp then local ok2,mh=pcall(function() return States:GetStateValue(c,"MaxHealth",150) end) return math.clamp(hp/(ok2 and mh or 150),0,1) end
    end
    local h=c:FindFirstChildOfClass("Humanoid"); return h and h.Health/h.MaxHealth or 0
end
local function GetDist(p)
    local c=p.Character; local lc=LocalPlayer.Character
    if not c or not lc then return 0 end
    local r=c:FindFirstChild("HumanoidRootPart"); local lr=lc:FindFirstChild("HumanoidRootPart")
    if not r or not lr then return 0 end
    return (r.Position-lr.Position).Magnitude
end
local function GetPart(p,name)
    local c=p.Character; if not c then return nil end
    if name=="Random" then
        local parts={}; for _,v in ipairs(c:GetChildren()) do if v:IsA("BasePart") then table.insert(parts,v) end end
        return #parts>0 and parts[math.random(1,#parts)] or c:FindFirstChild("HumanoidRootPart")
    end
    return c:FindFirstChild(name) or c:FindFirstChild("HumanoidRootPart")
end

-- ============================================================
--  VIS CACHE
-- ============================================================
local function VisCheck(char)
    local now=os.clock(); local c=AB_VisCache[char]
    if c and (now-c.t)<AB_VisCacheTTL then return c.v end
    local bone=char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    if not bone then AB_VisCache[char]={v=false,t=now} return false end
    local params=RaycastParams.new()
    params.FilterDescendantsInstances={LocalPlayer.Character or Instance.new("Folder")}
    params.FilterType=Enum.RaycastFilterType.Exclude
    local res=workspace:Raycast(Camera.CFrame.Position,bone.Position-Camera.CFrame.Position,params)
    local vis=res==nil or (res.Instance and res.Instance:IsDescendantOf(char))
    AB_VisCache[char]={v=vis,t=now}; return vis
end

