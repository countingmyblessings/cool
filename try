--  AIMBOT
-- ============================================================
UserInput.InputBegan:Connect(function(i,gpe) if gpe then return end if i.UserInputType==Enum.UserInputType.MouseButton1 then AB_IsFiring=true end end)
UserInput.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then AB_IsFiring=false end end)

local function IsTargetValid(p)
    if not p or p==LocalPlayer then return false end
    if AB_TeamCheck and IsSameTeam(p) then return false end
    if AB_DeathCheck and not IsAlive(p) then return false end
    resolve_player(p)
    local c=p.Character; if not c then return false end
    local part=GetPart(p,AB_Part); if not part then return false end
    if GetDist(p)>AB_MaxDist then return false end
    if AB_VisCheck and not VisCheck(c) then return false end
    local spos,vis=W2S(part.Position); if not vis then return false end
    return (spos-v2(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude<=AB_FOV
end
local function ScreenDist(p)
    local part=GetPart(p,AB_Part); if not part then return math.huge end
    local spos,vis=W2S(part.Position); if not vis then return math.huge end
    return (spos-v2(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
end
local function GetBestTarget()
    if AB_CurrentTarget and AB_CurrentTarget.Parent and IsTargetValid(AB_CurrentTarget) then
        local cd=ScreenDist(AB_CurrentTarget)
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=AB_CurrentTarget and IsTargetValid(p) and ScreenDist(p)<cd*0.55 then return p end
        end
        return AB_CurrentTarget
    end
    AB_CurrentTarget=nil
    local best,bd=nil,AB_FOV
    for _,p in ipairs(Players:GetPlayers()) do
        if IsTargetValid(p) then local d=ScreenDist(p) if d<bd then bd=d best=p end end
    end
    return best
end
local function GetPredPos(p)
    local part=GetPart(p,AB_Part); if not part then return nil end
    return part.Position+part.AssemblyLinearVelocity*AB_PredStrength
end
local function AimAt(p)
    if not p then return end
    local part=GetPart(p,AB_Part); if not part then return end
    local tpos=AB_PredEnabled and GetPredPos(p) or part.Position; if not tpos then return end
    local spos,vis=W2S(tpos); if not vis then return end
    local cx=Camera.ViewportSize.X/2; local cy=Camera.ViewportSize.Y/2
    local pxDist=(spos-v2(cx,cy)).Magnitude
    if CameraHandler and CameraHandler.currentRotation then
        local tCF=CFrame.lookAt(Camera.CFrame.Position,tpos)
        local tp,ty=tCF:ToEulerAnglesYXZ()
        local maxP=CameraHandler.maxPitch or 1.5673; tp=math.clamp(tp,-maxP,maxP)
        local cur=CameraHandler.currentRotation
        local dY=ty-cur.Y; while dY>math.pi do dY=dY-2*math.pi end; while dY<-math.pi do dY=dY+2*math.pi end
        local dP=tp-cur.X
        local spd=(AB_IsFiring and AB_SpeedAttack or AB_Smooth)*(AB_SpeedScale/100)
        spd=spd+(math.random()*2-1)*AB_SmoothVar
        if AB_Dropoff and pxDist<AB_DropoffThresh then spd=spd*(0.35+(pxDist/AB_DropoffThresh)*0.65) end
        if AB_FlickMode and pxDist>AB_FOV*0.6 then spd=spd*(1/AB_FlickStrength) end
        local alpha=math.clamp(spd,0.001,1)
        CameraHandler.currentRotation=Vector3.new(cur.X+dP*alpha,cur.Y+dY*alpha,0)
    else
        local spd=(AB_IsFiring and AB_SpeedAttack or AB_Smooth)*(AB_SpeedScale/100)
        spd=spd+(math.random()*2-1)*AB_SmoothVar
        local dx=(spos.X-cx)*spd; local dy=(spos.Y-cy)*spd
        if AB_Dropoff and pxDist<AB_DropoffThresh then dx=dx*(0.35+(pxDist/AB_DropoffThresh)*0.65); dy=dy*(0.35+(pxDist/AB_DropoffThresh)*0.65) end
        if AB_Jitter then dx=dx+(math.random()*2-1)*AB_JitterAmt; dy=dy+(math.random()*2-1)*AB_JitterAmt end
        pcall(function() mousemoverel(dx,dy) end)
    end
end

