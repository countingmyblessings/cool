-- ====================== AIMBOT LOGIC ======================
local function IsTargetValid(player)
    if not player then return false end
    if player == LocalPlayer then return false end
    if IsSameTeam(player) then return false end
    if Aim_DeathCheck and not IsAlive(player) then return false end
    resolve_player(player)
    local char = player.Character
    if not char then return false end
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return false end
    if Get_Distance(player) > Aim_Distance then return false end
    if Aim_Visible_Check and Is_Behind_Wall(target_part) then return false end
    local screen_pos, on_screen = World_To_Screen(target_part.Position)
    if not on_screen then return false end
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local dist = (screen_pos - screen_center).Magnitude
    if dist > Aim_FOV then return false end
    return true
end

local function GetScreenDistance(player)
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return math.huge end
    local screen_pos, on_screen = World_To_Screen(target_part.Position)
    if not on_screen then return math.huge end
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    return (screen_pos - screen_center).Magnitude
end

local function Get_Closest_Target()
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local closest_player = nil
    local closest_distance = Aim_FOV

    if Aim_CurrentTarget and Aim_CurrentTarget.Parent then
        if IsTargetValid(Aim_CurrentTarget) then
            local current_dist = GetScreenDistance(Aim_CurrentTarget)

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= Aim_CurrentTarget and IsTargetValid(player) then
                    local new_dist = GetScreenDistance(player)
                    if new_dist < current_dist * 0.6 then
                        closest_player = player
                        closest_distance = new_dist
                    end
                end
            end

            if closest_player then
                return closest_player
            end
            return Aim_CurrentTarget
        end
    end

    Aim_CurrentTarget = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if IsTargetValid(player) then
            local dist = GetScreenDistance(player)
            if dist < closest_distance then
                closest_distance = dist
                closest_player = player
            end
        end
    end
    return closest_player
end

local function Aim_At_Target(player)
    if not player then return end
    local char = player.Character
    if not char then return end
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return end
    if not CameraHandler or not CameraHandler.currentRotation then return end

    local targetPos = target_part.Position
    local camPos = Camera.CFrame.Position
    local targetCF = CFrame.lookAt(camPos, targetPos)
    local targetPitch, targetYaw, _ = targetCF:ToEulerAnglesYXZ()

    local maxPitch = CameraHandler.maxPitch or 1.5673
    targetPitch = math.clamp(targetPitch, -maxPitch, maxPitch)

    local currentRot = CameraHandler.currentRotation
    local currentPitch = currentRot.X
    local currentYaw = currentRot.Y

    local deltaYaw = targetYaw - currentYaw
    while deltaYaw > math.pi do
        deltaYaw = deltaYaw - 2 * math.pi
    end
    while deltaYaw < -math.pi do
        deltaYaw = deltaYaw + 2 * math.pi
    end

    local deltaPitch = targetPitch - currentPitch

    local base_speed = Aim_IsFiring and Aim_SpeedInAttack or Aim_Speed
    local effective_speed = base_speed * (Aim_SpeedScale / 100)
    local alpha = math.clamp(effective_speed, 0.001, 1)

    local newPitch = currentPitch + deltaPitch * alpha
    local newYaw = currentYaw + deltaYaw * alpha

    newPitch = math.clamp(newPitch, -maxPitch, maxPitch)
    CameraHandler.currentRotation = Vector3.new(newPitch, newYaw, 0)
end

-- ====================== ESP UPDATE ======================
local function Update_ESP()
    Cleanup_ESP()
    local screen_size = Camera.ViewportSize

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if IsSameTeam(player) then continue end
        resolve_player(player)
        local char = player.Character
        if not char then
            local d = ESP_Pool[player]
            if d then for _, drawing in pairs(d) do drawing.Visible = false end end
            continue
        end

        local hrp = char:FindFirstChild('HumanoidRootPart')
        local head = char:FindFirstChild('Head')
        if not hrp or not head then
            local d = ESP_Pool[player]
            if d then for _, drawing in pairs(d) do drawing.Visible = false end end
            continue
        end

        local root_pos, root_visible = World_To_Screen(hrp.Position)
        local head_pos, head_visible = World_To_Screen(head.Position + v3_new(0, 0.3, 0))

        local d = ESP_Pool[player]
        if not d then d = Create_ESP_Drawings(player) end

        if not root_visible and not head_visible then
            for _, drawing in pairs(d) do drawing.Visible = false end
            continue
        end

        local health = Get_Health(player)
        local distance = Get_Distance(player)
        local dist_str = tostring(math_floor(distance)) .. 'm'

        local effective_box_color = Box_Color
        local effective_name_color = Name_Color
        local effective_tracer_color = Tracer_Color
        local effective_dot_color = Head_Dot_Color

        if ESP_TeamColors then
            local tColor = GetTeamColor(player)
            if tColor then
                effective_box_color = tColor
                effective_name_color = tColor
                effective_tracer_color = tColor
                effective_dot_color = tColor
            end
        end

        local head_size = 2
        local head_y = head_pos.Y - head_size
        local root_y = root_pos.Y + 2
        local height = math_abs(root_y - head_y)
        local width = height * 0.55
        local box_x = root_pos.X - width / 2
        local box_y = head_pos.Y - head_size

        if Box_Enabled and ESP_Enabled then
            d.Box_Outline.Position = v2_new(box_x, box_y)
            d.Box_Outline.Size = v2_new(width, height)
            d.Box_Outline.Visible = true
            d.Box_Outline.Color = effective_box_color
            d.Box_Fill.Position = v2_new(box_x, box_y)
            d.Box_Fill.Size = v2_new(width, height)
            d.Box_Fill.Visible = true
        else
            d.Box_Outline.Visible = false
            d.Box_Fill.Visible = false
        end

        if Health_Enabled and ESP_Enabled then
            local bar_x = box_x - 6
            d.Health_Bar_BG.From = v2_new(bar_x, box_y)
            d.Health_Bar_BG.To = v2_new(bar_x, box_y + height)
            d.Health_Bar_BG.Visible = true
            local filled = height * health
            d.Health_Bar.From = v2_new(bar_x, box_y + height - filled)
            d.Health_Bar.To = v2_new(bar_x, box_y + height)
            d.Health_Bar.Visible = true
            local r = (1 - health) * 255
            local g = health * 255
            d.Health_Bar.Color = Color3.fromRGB(r, g, 40)
        else
            d.Health_Bar_BG.Visible = false
            d.Health_Bar.Visible = false
        end

        if Name_Enabled and ESP_Enabled then
            d.Name_Text.Text = player.DisplayName
            d.Name_Text.Position = v2_new(root_pos.X, box_y - 14)
            d.Name_Text.Visible = true
            d.Name_Text.Color = effective_name_color
        else
            d.Name_Text.Visible = false
        end

        if Distance_Enabled and ESP_Enabled then
            d.Distance_Text.Text = dist_str
            d.Distance_Text.Position = v2_new(root_pos.X, box_y + height + 4)
            d.Distance_Text.Visible = true
        else
            d.Distance_Text.Visible = false
        end

        if ESP_MatchAware or ESP_SpectateDetect then
            local status_parts = {}
            if ESP_MatchAware then
                local matchState = GetPlayerMatchState(player)
                if matchState ~= "unknown" then
                    table.insert(status_parts, matchState)
                end
            end
            if ESP_SpectateDetect and IsPlayerSpectating(player) then
                table.insert(status_parts, "SPECTATING")
            end
            if #status_parts > 0 then
                d.Status_Text.Text = table.concat(status_parts, " | ")
                d.Status_Text.Position = v2_new(root_pos.X, box_y + height + 18)
                d.Status_Text.Color = IsPlayerSpectating(player) and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(150, 150, 255)
                d.Status_Text.Visible = true
            else
                d.Status_Text.Visible = false
            end
        else
            d.Status_Text.Visible = false
        end

        if Tracer_Enabled and ESP_Enabled then
            local origin_x = screen_size.X / 2
            local origin_y = Tracer_Origin == 'Bottom' and screen_size.Y
                or Tracer_Origin == 'Top' and 0
                or screen_size.Y / 2
            d.Tracer_Line.From = v2_new(origin_x, origin_y)
            d.Tracer_Line.To = v2_new(root_pos.X, root_pos.Y)
            d.Tracer_Line.Visible = true
            d.Tracer_Line.Color = effective_tracer_color
        else
            d.Tracer_Line.Visible = false
        end

        if Head_Dot_Enabled and ESP_Enabled then
            d.Head_Dot.Position = head_pos
            d.Head_Dot.Visible = true
            d.Head_Dot.Color = effective_dot_color
        else
            d.Head_Dot.Visible = false
        end
    end
end

-- ====================== AIMBOT UPDATE ======================
local function Update_Aimbot()
    if not Aimbot_Enabled then
        Aim_CurrentTarget = nil
        Aim_IsReacting = false
        return
    end

    local now = tick()

    if Aim_MaxLockOnTime > 0 and Aim_CurrentTarget and (now - Aim_LockOnStart) >= Aim_MaxLockOnTime then
        Aim_CurrentTarget = nil
        Aim_IsReacting = false
        return
    end

    local target = Get_Closest_Target()

    if target ~= Aim_CurrentTarget then
        if target then
            if not Aim_IsReacting then
                Aim_IsReacting = true
                Aim_ReactionStart = now
                return
            end

            local reaction_seconds = Aim_ReactionTime / 1000
            if (now - Aim_ReactionStart) < reaction_seconds then
                return
            end

            Aim_CurrentTarget = target
            Aim_LockOnStart = now
            Aim_IsReacting = false
        else
            Aim_CurrentTarget = nil
            Aim_IsReacting = false
            return
        end
    end

    if Aim_CurrentTarget then
        Aim_At_Target(Aim_CurrentTarget)
    end
end

-- ====================== FOV UPDATE ======================
local function Update_FOV()
    if not FOV_Circle_Enabled then
        FOV_Drawing.Visible = false
        return
    end
    local center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOV_Drawing.Position = center
    FOV_Drawing.Radius = Aim_FOV
    FOV_Drawing.Color = FOV_Circle_Color
    FOV_Drawing.Thickness = 1.5
    FOV_Drawing.NumSides = 100
    if FOV_FillStyle == 'Outline' then
        FOV_Drawing.Filled = false
        FOV_Drawing.Transparency = FOV_Circle_Transparency
    elseif FOV_FillStyle == 'Half Full' then
        FOV_Drawing.Filled = true
        FOV_Drawing.Transparency = 0.7
    elseif FOV_FillStyle == 'Fully Full' then
        FOV_Drawing.Filled = true
        FOV_Drawing.Transparency = 0.3
    end
    FOV_Drawing.Visible = true
end

-- ====================== BOT ESP ======================
local function Create_Bot_Drawings()
    local d = {}
    d.Box = Drawing.new('Square')
    d.Box.Visible = false
    d.Box.Filled = false
    d.Box.Thickness = 2
    d.Box.ZIndex = 5
    d.Label = Drawing.new('Text')
    d.Label.Visible = false
    d.Label.Size = 13
    d.Label.Center = true
    d.Label.Outline = true
    d.Label.Font = Drawing.Fonts.Plex
    d.Label.ZIndex = 5
    d.Dot = Drawing.new('Circle')
    d.Dot.Visible = false
    d.Dot.Filled = true
    d.Dot.Radius = 3
    d.Dot.NumSides = 12
    d.Dot.ZIndex = 6
    return d
end

local function Update_BotESP()
    if not BotESP_Enabled then
        for ent, d in pairs(BotESP_Pool) do
            for _, drawing in pairs(d) do
                pcall(function() drawing.Visible = false end)
            end
        end
        return
    end

    local world = Workspace:FindFirstChild('World')
    if not world then return end
    local entities = world:FindFirstChild('Entities')
    if not entities then return end

    for ent, d in pairs(BotESP_Pool) do
        if not ent.Parent then
            for _, drawing in pairs(d) do
                pcall(function() drawing:Remove() end)
            end
            BotESP_Pool[ent] = nil
        end
    end

    for _, ent in ipairs(entities:GetChildren()) do
        if ent:GetAttribute('IsDummy') ~= true then continue end
        local hrp = ent:FindFirstChild('HumanoidRootPart')
        if not hrp then continue end
        local root_pos, root_visible = World_To_Screen(hrp.Position)
        local head = ent:FindFirstChild('Head')
        local head_pos, head_visible
        if head then
            head_pos, head_visible = World_To_Screen(head.Position + v3_new(0, 0.5, 0))
        end

        if not root_visible and not head_visible then
            if BotESP_Pool[ent] then
                for _, drawing in pairs(BotESP_Pool[ent]) do drawing.Visible = false end
            end
            continue
        end

        local isFinisher = ent:GetAttribute('Finisher') == true
        local color = isFinisher and BotESP_FinisherColor or BotESP_Color

        if not BotESP_Pool[ent] then BotESP_Pool[ent] = Create_Bot_Drawings() end
        local d = BotESP_Pool[ent]

        local head_y = head_pos and head_pos.Y or (root_pos.Y - 3)
        local root_y = root_pos.Y + 2
        local height = math_abs(root_y - head_y)
        local width = height * 0.55
        local box_x = root_pos.X - width / 2
        local box_y = head_y - 2

        d.Box.Position = v2_new(box_x, box_y)
        d.Box.Size = v2_new(width, height)
        d.Box.Color = color
        d.Box.Visible = true

        local label_text = isFinisher and 'BOT [FINISHER]' or 'BOT'
        if BotESP_ShowID then
            local botID = ent:GetAttribute('BotUserId')
            label_text = label_text .. ' #' .. tostring(botID or '?')
        end
        d.Label.Text = label_text
        d.Label.Position = v2_new(root_pos.X, box_y - 14)
        d.Label.Color = color
        d.Label.Visible = true

        if head_pos and head_visible then
            d.Dot.Position = head_pos
            d.Dot.Color = color
            d.Dot.Visible = true
        else
            d.Dot.Visible = false
        end
    end
end

-- ====================== RAINBOW ======================
local function Update_Rainbow()
    if not Rainbow_Enabled then return end
    Rainbow_Hue = (Rainbow_Hue + Rainbow_Speed) % 1
    local color = Color3.fromHSV(Rainbow_Hue, 1, 1)

    for _, target in ipairs(Rainbow_Targets) do
        if target == 'Box' then Box_Color = color end
        if target == 'Name' then Name_Color = color end
        if target == 'Tracer' then Tracer_Color = color end
        if target == 'HeadDot' then Head_Dot_Color = color end
        if target == 'FOV' then FOV_Circle_Color = color end
    end
end

-- ====================== KILL FEED ======================
local function SetupKillFeedListener()
    task.delay(4, function()
        pcall(function()
            if Neuron and Neuron.net and Neuron.net.packets then
                local packet = Neuron.net.packets.round_died
                if packet and packet.Connect then
                    packet:Connect(function(data)
                        if not KF_Enabled then return end
                        if not data then return end

                        local killed = data.player
                        local killer = data.killer
                        local assist = data.assistingPlayer
                        local headshot = data.headShot
                        local weaponID = data.weaponID

                        if not killed then return end

                        local killerName = killer and killer.DisplayName or "World"
                        local killedName = killed.DisplayName
                        local assistName = assist and assist.DisplayName or nil

                        local weaponName = weaponID or "weapon"
                        local weaponAliases = {
                            ["burst"] = "Burst Carbine", ["handgun"] = "Pistol",
                            ["tec9"] = "Tec-9", ["flintlock"] = "Flintlock",
                            ["bolt_action_sniper"] = "Sniper", ["taser"] = "Tazer",
                            ["satchel"] = "Satchel", ["fist"] = "Knife",
                            ["ak47"] = "AK-47", ["ar"] = "Assault Rifle",
                            ["deagle"] = "Desert Eagle", ["minigun"] = "Minigun",
                            ["pistol"] = "Pistol", ["pulse_rifle"] = "Pulse Rifle",
                            ["raygun"] = "Ray Gun", ["rpg"] = "RPG",
                            ["shotgun"] = "Shotgun", ["sniper"] = "Sniper",
                            ["scar_h"] = "SCAR-H", ["lmg"] = "LMG",
                            ["tommy_gun"] = "Tommy Gun", ["knife"] = "Knife",
                            ["karambit"] = "Karambit", ["katana"] = "Katana",
                            ["butterfly_knife"] = "Butterfly Knife",
                            ["scythe"] = "Scythe", ["shorty"] = "Shorty",
                            ["grenade"] = "Grenade", ["molotov"] = "Molotov",
                            ["precision_burst_carbine"] = "Burst Carbine",
                            ["tazer"] = "Tazer", ["satchel_explosive"] = "Satchel",
                            ["flintlock_pistol"] = "Flintlock", ["tec-9"] = "Tec-9",
                        }
                        if weaponAliases[weaponName] then
                            weaponName = weaponAliases[weaponName]
                        end

                        local text = killerName .. " > " .. killedName .. " [" .. weaponName .. "]"
                        if headshot then text = text .. " [HS]" end
                        if assistName then text = text .. " (+ " .. assistName .. ")" end

                        local entry = Drawing.new('Text')
                        entry.Text = text
                        entry.Size = 14
                        entry.Center = false
                        entry.Outline = true
                        entry.Font = Drawing.Fonts.Plex
                        entry.Color = headshot and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(255, 255, 255)
                        entry.Visible = true

                        table.insert(KF_Pool, {
                            drawing = entry,
                            expire = tick() + KF_Duration,
                            duration = KF_Duration
                        })

                        while #KF_Pool > KF_MaxEntries do
                            local old = table.remove(KF_Pool, 1)
                            pcall(function() old.drawing:Remove() end)
                        end
                    end)
                end
            end
        end)
    end)
end

SetupKillFeedListener()

local function Update_KillFeed()
    local now = tick()
    local screen_size = Camera.ViewportSize
    local y_start = 150

    for i = #KF_Pool, 1, -1 do
        local entry = KF_Pool[i]
        if now > entry.expire then
            pcall(function() entry.drawing:Remove() end)
            table.remove(KF_Pool, i)
        else
            local remaining = (entry.expire - now) / entry.duration
            local fade = math.clamp(remaining * 2, 0, 1)
            entry.drawing.Position = v2_new(screen_size.X - 350, y_start + (#KF_Pool - i) * 20)
            entry.drawing.Transparency = 1 - fade
        end
    end
end

-- ====================== DEVICE CHANGER ======================
local function TryHookDataHandler()
    if DC_Hooked then return end
    if not DataHandler then return end
    if not DataHandler.GetDataAsync then return end

    pcall(function()
        local original = DataHandler.GetDataAsync
        DataHandler.GetDataAsync = function(self, player, ...)
            local result = original(self, player, ...)
            if player == LocalPlayer and DC_Enabled and result then
                result.Device = DC_Device == "default" and nil or tonumber(DC_Device)
            end
            return result
        end
        DC_Hooked = true
    end)
end

task.delay(4.5, function()
    TryHookDataHandler()
end)

local function Update_DeviceChanger()
    if not DC_Enabled then return end
    if not GameplayHandler then return end

    pcall(function()
        if GameplayHandler.playerFrame then
            local deviceFrame = GameplayHandler.playerFrame:FindFirstChild("Device")
            if deviceFrame then
                local icon = deviceFrame:FindFirstChild("Icon")
                if icon and icon:IsA("ImageLabel") then
                    local deviceOffsets = {
                        ["1"] = { Vector2.new(104, 154), Vector2.new(48, 72) },
                        ["2"] = { Vector2.new(166, 154), Vector2.new(102, 72) },
                        ["default"] = { Vector2.new(0, 154), Vector2.new(90, 72) }
                    }
                    local offset = deviceOffsets[DC_Device] or deviceOffsets["default"]
                    icon.ImageRectOffset = offset[1]
                    icon.ImageRectSize = offset[2]
                end
            end
        end
    end)
end

-- ====================== UNLOCK ALL ======================
local function InitUnlockAll()
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        local RF = game:GetService("ReplicatedFirst")
        local LP = Players.LocalPlayer
        local RunService = game:GetService("RunService")

        local Milk = require(RS:WaitForChild("Milk"))
        Milk.Constants.UnlockAllUserIds = Milk.Constants.UnlockAllUserIds or {}
        Milk.Constants.UnlockAllUserIds[LP.UserId] = true
        Milk:Init()

        local w2n, nidToWName = {}, {}
        for name, data in pairs(Milk.Directory.Items.all) do
            if type(data) == "table" and data.nID then
                local nid = data.nID
                w2n[name] = nid
                nidToWName[nid] = name
                nidToWName[tostring(nid)] = name
            end
        end

        local CONFIG_PATH = "overkill_skins.json"
        local DEFAULTS = {
            ak47 = "", shotgun = "", deagle = "",
            handgun = "", tec9 = "", katana = "",
            scythe = "", karambit = "", shorty = "",
            raygun = "", medkit = "", minigun = "",
            grenade = "", rpg = "", burst = "",
            pulse_rifle = "", bolt_action_sniper = "", tommy_gun = "",
        }

        local function loadConfig()
            local ok, data = pcall(readfile, CONFIG_PATH)
            if ok and data and data ~= "" then
                local ok2, tbl = pcall(HttpService.JSONDecode, HttpService, data)
                if ok2 and type(tbl) == "table" then return tbl end
            end
            return {}
        end

        local function saveConfig()
            local ok, json = pcall(function() return HttpService:JSONEncode(getgenv().__Equipped) end)
            if ok then pcall(writefile, CONFIG_PATH, json) end
        end

        getgenv().__Equipped = loadConfig()
        if next(getgenv().__Equipped) == nil then
            for k, v in pairs(DEFAULTS) do getgenv().__Equipped[k] = v end
            saveConfig()
        end
        local function getSkin(w) return getgenv().__Equipped[w] or DEFAULTS[w] end

        local dh = Milk.Handlers.DataHandler

        if dh and dh.GetDataAsync then
            local orig = dh.GetDataAsync
            dh.GetDataAsync = function(self, ...)
                local data = orig(self, ...)
                if type(data) == "table" and type(data.Items) == "table" then
                    local real = data.Items
                    data.Items = setmetatable({}, {
                        __index = function(t, nid)
                            local r = real[nid]
                            if not r then return nil end
                            local wName = nidToWName[nid] or nidToWName[tostring(nid)]
                            if wName then
                                local s = getSkin(wName)
                                if s then
                                    local item = {}
                                    for k, v in next, r do item[k] = v end
                                    item.skin = s
                                    return item
                                end
                            end
                            return r
                        end,
                        __newindex = function(t, k, v) real[k] = v end,
                        __pairs = function() return pairs(real) end
                    })
                end
                return data
            end
        end

        pcall(function()
            local neuron = require(RF:WaitForChild("neuron"))
            if neuron and neuron.net and neuron.net.packets and neuron.net.packets.armory_change_skin then
                local pkt = neuron.net.packets.armory_change_skin
                local orig = pkt.Fire
                pkt.Fire = function(self, weaponName, skinName)
                    if type(weaponName) == "string" and type(skinName) == "string" then
                        getgenv().__Equipped[weaponName] = skinName
                        saveConfig()
                    end
                    return orig(self, weaponName, skinName)
                end
            end
        end)

        local chickModule = require(RF.Packages.Chickynoid.Client.ClientModule)
        RunService.Heartbeat:Connect(function()
            pcall(function()
                local chick = chickModule.localChickynoid
                if not chick or not chick.simulation then return end
                local state = chick.simulation.state
                if not state then return end
                for i = 1, 4 do
                    local wid = state["slot" .. i .. "_weaponID"]
                    if wid and wid ~= "" then
                        local s = getSkin(wid)
                        if s then state["slot" .. i .. "_skin"] = s end
                    end
                end
            end)
        end)
    end)
end

