local function Update_Profile_Spoof()
    if not PP_Enabled then return end
    pcall(function()
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if not playerGui then return end
        local lobby = playerGui:FindFirstChild("Lobby")
        if not lobby then return end
        local profile = lobby:FindFirstChild("PlayerProfile")
        if not profile then return end
        local main = profile:FindFirstChild("Main")
        if not main then return end
        
        for _, desc in ipairs(main:GetDescendants()) do
            if desc:IsA("TextLabel") then
                local name = desc.Name:lower()
                local text = desc.Text:lower()
                if name:find("level") or name:find("lvl") or text:find("lvl") or text:find("level") then
                    desc.Text = "Lvl. " .. tostring(PP_Level)
                elseif name:find("streak") or name:find("ws") or text:find("streak") or text:find("ws") then
                    desc.Text = tostring(PP_Streak) .. " WS"
                end
            end
        end
    end)
end

