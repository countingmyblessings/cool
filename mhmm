			lastEquippedSlot = targetWeapon
			local keyCode
			if targetWeapon == "Primary" then
				keyCode = Enum.KeyCode.One
			elseif targetWeapon == "Secondary" then
				keyCode = Enum.KeyCode.Two
			elseif targetWeapon == "Extra" then
				keyCode = Enum.KeyCode.Three
